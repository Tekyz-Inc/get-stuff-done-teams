, 'marker absent');\n    return;\n  }\n  const step2Idx = md.indexOf('## Step 2');\n  // Allow Step 2.5 to follow.\n  const step3Idx = md.indexOf('## Step 3');\n  assert.ok(step2Idx > 0, 'verify.md must declare Step 2');\n  assert.ok(markerIdx > step2Idx, 'wire-in marker must be inside Step 2 (after the heading)');\n  if (step3Idx > 0) {\n    assert.ok(markerIdx < step3Idx, 'wire-in marker must precede Step 3');\n  }\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1283,"cache_read_input_tokens":129841,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1283},"output_tokens":65,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"d7a22423-cc58-497c-b885-89dea884b91e","uuid":"9a8859ea-378a-47f0-8c1e-42d836f2be26"}
