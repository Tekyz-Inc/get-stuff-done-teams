{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ERjnn9sMj8easyP2akMAig","type":"tool_result","content":"1\t'use strict';\n2\t\n3\t/**\n4\t * M55 D1 — cli-preflight library: envelope shape + library API + CLI integration tests.\n5\t *\n6\t * Per-check happy/fail tests live in test/m55-d1-cli-preflight-checks/.\n7\t */\n8\t\n9\tconst test = require('node:test');\n10\tconst assert = require('node:assert/strict');\n11\tconst fs = require('node:fs');\n12\tconst os = require('node:os');\n13\tconst path = require('node:path');\n14\tconst { execFileSync } = require('node:child_process');\n15\t\n16\tconst lib = require('../bin/cli-preflight.cjs');\n17\tconst LIB_PATH = path.resolve(__dirname, '..', 'bin', 'cli-preflight.cjs');\n18\t\n19\tfunction makeTmpProject() {\n20\t  const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'gsd-t-m55-d1-'));\n21\t  // git init so checks that use git won't blow up.\n22\t  try {\n23\t    execFileSync('git', ['init', '-q'], { cwd: dir, stdio: 'ignore' });\n24\t    execFileSync('git', ['config', 'user.email', 'test@example.com'], { cwd: dir, stdio: 'ignore' });\n25\t    execFileSync('git', ['config', 'user.name', 'test'], { cwd: dir, stdio: 'ignore' });\n26\t    execFileSync('git', ['commit', '--allow-empty', '-m', 'init', '-q'], { cwd: dir, stdio: 'ignore' });\n27\t  } catch (_) {\n28\t    // git might not be available; tests that need it will skip.\n29\t  }\n30\t  return dir;\n31\t}\n32\t\n33\tfunction cleanup(dir) {\n34\t  try { fs.rmSync(dir, { recursive: true, force: true }); } catch (_) {}\n35\t}\n36\t\n37\t// ── Envelope shape ──────────────────────────────────────────────────────────\n38\t\n39\ttest('runPreflight: returns v1.0.0 envelope shape', () => {\n40\t  const dir = makeTmpProject();"}]},"parent_tool_use_id":null,"session_id":"d7a22423-cc58-497c-b885-89dea884b91e","uuid":"c230412c-ca71-4ff7-8db8-ee974108fa09","timestamp":"2026-05-10T00:12:01.791Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/david/projects/GSD-T/test/m55-d1-cli-preflight.test.js","content":"'use strict';\n\n/**\n * M55 D1 — cli-preflight library: envelope shape + library API + CLI integration tests.\n *\n * Per-check happy/fail tests live in test/m55-d1-cli-preflight-checks/.\n */\n\nconst test = require('node:test');\nconst assert = require('node:assert/strict');\nconst fs = require('node:fs');\nconst os = require('node:os');\nconst path = require('node:path');\nconst { execFileSync } = require('node:child_process');\n\nconst lib = require('../bin/cli-preflight.cjs');\nconst LIB_PATH = path.resolve(__dirname, '..', 'bin', 'cli-preflight.cjs');\n\nfunction makeTmpProject() {\n  const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'gsd-t-m55-d1-'));\n  // git init so checks that use git won't blow up.\n  try {\n    execFileSync('git', ['init', '-q'], { cwd: dir, stdio: 'ignore' });\n    execFileSync('git', ['config', 'user.email', 'test@example.com'], { cwd: dir, stdio: 'ignore' });\n    execFileSync('git', ['config', 'user.name', 'test'], { cwd: dir, stdio: 'ignore' });\n    execFileSync('git', ['commit', '--allow-empty', '-m', 'init', '-q'], { cwd: dir, stdio: 'ignore' });\n  } catch (_) {\n    // git might not be available; tests that need it will skip.\n  }\n  return dir;\n}\n\nfunction cleanup(dir) {\n  try { fs.rmSync(dir, { recursive: true, force: true }); } catch (_) {}\n}\n\n// ── Envelope shape ──────────────────────────────────────────────────────────\n\ntest('runPreflight: returns v1.0.0 envelope shape', () => {\n  const dir = makeTmpProject();","numLines":40,"startLine":1,"totalLines":368}}}
