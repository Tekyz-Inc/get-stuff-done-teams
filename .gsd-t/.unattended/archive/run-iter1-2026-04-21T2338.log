{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016rBbf3pdvWMMp9YKPX5p2X","type":"tool_result","content":"1\t'use strict';\n2\t/**\n3\t * M43 D1 — in-session usage capture (Branch B: transcript-sourced).\n4\t *\n5\t * Covers:\n6\t *   - One-turn: fabricated transcript with 1 assistant usage line → 1 v2 row\n7\t *   - Multi-turn: 3 assistant usage lines → 3 v2 rows, distinct turn_id\n8\t *   - Dedup: repeated hook fire over the same transcript emits zero new rows\n9\t *   - Appended turns: a new turn after a cursor → exactly the delta emitted\n10\t *   - Missing usage: assistant line without `usage` is ignored (no row)\n11\t *   - Non-assistant lines: user lines are skipped\n12\t *   - Missing transcript: processHookPayload returns reason=missing-*\n13\t *   - captureInSessionUsage: direct call with null usage writes an `—` row\n14\t */\n15\t\n16\tconst test = require('node:test');\n17\tconst assert = require('node:assert/strict');\n18\tconst fs = require('node:fs');\n19\tconst os = require('node:os');\n20\tconst path = require('node:path');\n21\t\n22\tconst inSession = require('../bin/gsd-t-in-session-usage.cjs');\n23\t\n24\tfunction makeTmpProject() {\n25\t  const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'gsd-t-m43-d1-'));\n26\t  fs.mkdirSync(path.join(dir, '.gsd-t'), { recursive: true });\n27\t  return dir;\n28\t}\n29\t\n30\tfunction cleanup(dir) {\n31\t  try { fs.rmSync(dir, { recursive: true, force: true }); } catch (_) {}\n32\t}\n33\t\n34\tfunction writeTranscript(dir, name, lines) {\n35\t  const p = path.join(dir, name);\n36\t  fs.writeFileSync(p, lines.map(l => JSON.stringify(l)).join('\\n') + '\\n');\n37\t  return p;\n38\t}\n39\t\n40\tfunction readJsonlLines(p) {\n41\t  if (!fs.existsSync(p)) return [];\n42\t  return fs.readFileSync(p, 'utf8').split('\\n').filter(Boolean).map(JSON.parse);\n43\t}\n44\t\n45\tfunction assistantLine(id, usage, tsIso) {\n46\t  return {\n47\t    type: 'assistant',\n48\t    uuid: `uuid-${id}`,\n49\t    timestamp: tsIso || '2026-04-21T23:00:00.000Z',\n50\t    message: {\n51\t      id: `msg_${id}`,\n52\t      model: 'claude-opus-4-7',\n53\t      role: 'assistant',\n54\t      usage,\n55\t    },\n56\t  };\n57\t}\n58\t\n59\tconst USAGE_A = { input_tokens: 10, output_tokens: 5, cache_read_input_tokens: 100, cache_creation_input_tokens: 0, total_cost_usd: 0.01 };\n60\tconst USAGE_B = { input_tokens: 12, output_tokens: 7, cache_read_input_tokens: 110, cache_creation_input_tokens: 3, total_cost_usd: 0.02 };\n61\tconst USAGE_C = { input_tokens: 8,  output_tokens: 4, cache_read_input_tokens: 120, cache_creation_input_tokens: 1, total_cost_usd: 0.015 };\n62\t\n63\t// ── One-turn ──────────────────────────────────────────────────────────────\n64\t\n65\ttest('D1: one assistant turn → one in-session v2 row', () => {\n66\t  const dir = makeTmpProject();\n67\t  try {\n68\t    const tp = writeTranscript(dir, 'transcript.jsonl', [\n69\t      assistantLine('a', USAGE_A),\n70\t    ]);\n71\t    const r = inSession.processHookPayload({\n72\t      projectDir: dir,\n73\t      payload: {\n74\t        session_id: 'session-1',\n75\t        transcript_path: tp,\n76\t        cwd: dir,\n77\t        hook_event_name: 'Stop',\n78\t      },\n79\t    });\n80\t    assert.equal(r.emitted, 1);\n81\t    assert.equal(r.sessionId, 'session-1');\n82\t\n83\t    const rows = readJsonlLines(path.join(dir, '.gsd-t', 'metrics', 'token-usage.jsonl'));\n84\t    assert.equal(rows.length, 1);\n85\t    assert.equal(rows[0].schemaVersion, 2);\n86\t    assert.equal(rows[0].sessionType, 'in-session');\n87\t    assert.equal(rows[0].session_id, 'session-1');\n88\t    assert.equal(rows[0].turn_id, 'msg_a');\n89\t    assert.equal(rows[0].inputTokens, 10);\n90\t    assert.equal(rows[0].outputTokens, 5);\n91\t    assert.equal(rows[0].cacheReadInputTokens, 100);\n92\t    assert.equal(rows[0].costUSD, 0.01);\n93\t    assert.equal(rows[0].model, 'claude-opus-4-7');\n94\t  } finally { cleanup(dir); }\n95\t});\n96\t\n97\t// ── Multi-turn ────────────────────────────────────────────────────────────\n98\t\n99\ttest('D1: three assistant turns → three rows with distinct turn_id', () => {\n100\t  const dir = makeTmpProject();\n101\t  try {\n102\t    const tp = writeTranscript(dir, 'transcript.jsonl', [\n103\t      assistantLine('a', USAGE_A, '2026-04-21T23:00:00.000Z'),\n104\t      assistantLine('b', USAGE_B, '2026-04-21T23:01:00.000Z'),\n105\t      assistantLine('c', USAGE_C, '2026-04-21T23:02:00.000Z'),\n106\t    ]);\n107\t    const r = inSession.processHookPayload({\n108\t      projectDir: dir,\n109\t      payload: { session_id: 'session-multi', transcript_path: tp, cwd: dir, hook_event_name: 'Stop' },\n110\t    });\n111\t    assert.equal(r.emitted, 3);\n112\t\n113\t    const rows = readJsonlLines(path.join(dir, '.gsd-t', 'metrics', 'token-usage.jsonl'));\n114\t    assert.equal(rows.length, 3);\n115\t    const turnIds = rows.map(r => r.turn_id);\n116\t    assert.deepEqual(turnIds, ['msg_a', 'msg_b', 'msg_c']);\n117\t    assert.ok(rows.every(r => r.session_id === 'session-multi'));\n118\t    assert.ok(rows.every(r => r.sessionType === 'in-session'));\n119\t  } finally { cleanup(dir); }\n120\t});\n121\t\n122\t// ── Dedup: repeated hook fire ─────────────────────────────────────────────\n123\t\n124\ttest('D1: repeated hook fire over same transcript emits zero new rows', () => {\n125\t  const dir = makeTmpProject();\n126\t  try {\n127\t    const tp = writeTranscript(dir, 'transcript.jsonl', [\n128\t      assistantLine('a', USAGE_A),\n129\t      assistantLine('b', USAGE_B),\n130\t    ]);\n131\t    const payload = { session_id: 'session-dedup', transcript_path: tp, cwd: dir, hook_event_name: 'Stop' };\n132\t\n133\t    const r1 = inSession.processHookPayload({ projectDir: dir, payload });\n134\t    assert.equal(r1.emitted, 2);\n135\t\n136\t    const r2 = inSession.processHookPayload({ projectDir: dir, payload });\n137\t    assert.equal(r2.emitted, 0);\n138\t    assert.equal(r2.skipped, 2);\n139\t\n140\t    const rows = readJsonlLines(path.join(dir, '.gsd-t', 'metrics', 'token-usage.jsonl'));\n141\t    assert.equal(rows.length, 2);\n142\t  } finally { cleanup(dir); }\n143\t});\n144\t\n145\t// ── Appended-turn delta ───────────────────────────────────────────────────\n146\t\n147\ttest('D1: a turn appended after first fire emits exactly one new row', () => {\n148\t  const dir = makeTmpProject();\n149\t  try {\n150\t    const tp = path.join(dir, 'transcript.jsonl');\n151\t    fs.writeFileSync(tp, JSON.stringify(assistantLine('a', USAGE_A)) + '\\n');\n152\t    const payload = { session_id: 'session-delta', transcript_path: tp, cwd: dir, hook_event_name: 'Stop' };\n153\t\n154\t    const r1 = inSession.processHookPayload({ projectDir: dir, payload });\n155\t    assert.equal(r1.emitted, 1);\n156\t\n157\t    fs.appendFileSync(tp, JSON.stringify(assistantLine('b', USAGE_B)) + '\\n');\n158\t    const r2 = inSession.processHookPayload({ projectDir: dir, payload });\n159\t    assert.equal(r2.emitted, 1);\n160\t    assert.equal(r2.skipped, 1);\n161\t\n162\t    const rows = readJsonlLines(path.join(dir, '.gsd-t', 'metrics', 'token-usage.jsonl'));\n163\t    assert.equal(rows.length, 2);\n164\t    assert.deepEqual(rows.map(r => r.turn_id), ['msg_a', 'msg_b']);\n165\t  } finally { cleanup(dir); }\n166\t});\n167\t\n168\t// ── Missing usage / non-assistant lines ───────────────────────────────────\n169\t\n170\ttest('D1: assistant line without usage is ignored; user lines are skipped', () => {\n171\t  const dir = makeTmpProject();\n172\t  try {\n173\t    const tp = writeTranscript(dir, 'transcript.jsonl', [\n174\t      { type: 'user', uuid: 'u-1', timestamp: '2026-04-21T23:00:00Z', message: { role: 'user', content: 'hi' } },\n175\t      { type: 'assistant', uuid: 'a-no-usage', timestamp: '2026-04-21T23:00:01Z', message: { id: 'msg_noup', model: 'claude-opus-4-7', role: 'assistant' } },\n176\t      assistantLine('good', USAGE_A, '2026-04-21T23:00:02Z'),\n177\t    ]);\n178\t    const r = inSession.processHookPayload({\n179\t      projectDir: dir,\n180\t      payload: { session_id: 'session-filter', transcript_path: tp, cwd: dir, hook_event_name: 'Stop' },\n181\t    });\n182\t    assert.equal(r.emitted, 1);\n183\t    const rows = readJsonlLines(path.join(dir, '.gsd-t', 'metrics', 'token-usage.jsonl'));\n184\t    assert.equal(rows.length, 1);\n185\t    assert.equal(rows[0].turn_id, 'msg_good');\n186\t  } finally { cleanup(dir); }\n187\t});\n188\t\n189\t// ── Missing transcript / missing session ──────────────────────────────────\n190\t\n191\ttest('D1: missing transcript_path returns reason=missing-session-or-transcript', () => {\n192\t  const dir = makeTmpProject();\n193\t  try {\n194\t    const r = inSession.processHookPayload({\n195\t      projectDir: dir,\n196\t      payload: { session_id: 'session-x', cwd: dir, hook_event_name: 'Stop' },\n197\t    });\n198\t    assert.equal(r.emitted, 0);\n199\t    assert.equal(r.reason, 'missing-session-or-transcript');\n200\t  } finally { cleanup(dir); }\n201\t});\n202\t\n203\ttest('D1: non-existent transcript returns reason=no-turns (graceful)', () => {\n204\t  const dir = makeTmpProject();\n205\t  try {\n206\t    const r = inSession.processHookPayload({\n207\t      projectDir: dir,\n208\t      payload: {\n209\t        session_id: 'session-x',\n210\t        transcript_path: path.join(dir, 'does-not-exist.jsonl'),\n211\t        cwd: dir,\n212\t        hook_event_name: 'Stop',\n213\t      },\n214\t    });\n215\t    assert.equal(r.emitted, 0);\n216\t    assert.equal(r.reason, 'no-turns');\n217\t  } finally { cleanup(dir); }\n218\t});\n219\t\n220\t// ── Direct captureInSessionUsage — null usage emits `—` row ───────────────\n221\t\n222\ttest('D1: captureInSessionUsage with null usage writes a row with hasUsage=false', () => {\n223\t  const dir = makeTmpProject();\n224\t  try {\n225\t    inSession.captureInSessionUsage({\n226\t      projectDir: dir,\n227\t      sessionId: 'session-direct',\n228\t      turnId: 'msg_direct',\n229\t      usage: null,\n230\t    });\n231\t    const rows = readJsonlLines(path.join(dir, '.gsd-t', 'metrics', 'token-usage.jsonl'));\n232\t    assert.equal(rows.length, 1);\n233\t    assert.equal(rows[0].hasUsage, false);\n234\t    assert.equal(rows[0].sessionType, 'in-session');\n235\t    assert.equal(rows[0].session_id, 'session-direct');\n236\t    assert.equal(rows[0].turn_id, 'msg_direct');\n237\t    // In-session path writes JSONL only (skipMarkdownLog=true). The markdown\n238\t    // log is regenerated on demand via `gsd-t tokens --regenerate-log`.\n239\t    assert.equal(\n240\t      fs.existsSync(path.join(dir, '.gsd-t', 'token-log.md')),\n241\t      false,\n242\t      'token-log.md should NOT be written by per-turn in-session capture',\n243\t    );\n244\t  } finally { cleanup(dir); }\n245\t});\n246\t\n247\ttest('D1: multi-turn emission does NOT append to token-log.md (JSONL-only)', () => {\n248\t  const dir = makeTmpProject();\n249\t  try {\n250\t    const tp = writeTranscript(dir, 'transcript.jsonl', [\n251\t      assistantLine('a', USAGE_A),\n252\t      assistantLine('b', USAGE_B),\n253\t      assistantLine('c', USAGE_C),\n254\t    ]);\n255\t    inSession.processHookPayload({\n256\t      projectDir: dir,\n257\t      payload: { session_id: 'session-md', transcript_path: tp, cwd: dir, hook_event_name: 'Stop' },\n258\t    });\n259\t    assert.equal(\n260\t      fs.existsSync(path.join(dir, '.gsd-t', 'token-log.md')),\n261\t      false,\n262\t      'token-log.md should stay untouched by in-session captures',\n263\t    );\n264\t    const rows = readJsonlLines(path.join(dir, '.gsd-t', 'metrics', 'token-usage.jsonl'));\n265\t    assert.equal(rows.length, 3);\n266\t  } finally { cleanup(dir); }\n267\t});\n268\t\n269\t// ── Real probe payload shape (golden-style) ───────────────────────────────\n270\t\n271\ttest('D1: real-probe-shaped payload (session_id + transcript_path + cwd) processes without error', () => {\n272\t  const dir = makeTmpProject();\n273\t  try {\n274\t    const tp = writeTranscript(dir, 'transcript.jsonl', [\n275\t      assistantLine('real', USAGE_A),\n276\t    ]);\n277\t    const payload = {\n278\t      session_id: 'a5ee3b8e-1a77-4950-ab8d-f108af026c1d',\n279\t      transcript_path: tp,\n280\t      cwd: dir,\n281\t      permission_mode: 'bypassPermissions',\n282\t      hook_event_name: 'Stop',\n283\t      stop_hook_active: false,\n284\t      last_assistant_message: 'truncated...',\n285\t    };\n286\t    const r = inSession.processHookPayload({ projectDir: dir, payload });\n287\t    assert.equal(r.emitted, 1);\n288\t    assert.equal(r.sessionId, 'a5ee3b8e-1a77-4950-ab8d-f108af026c1d');\n289\t  } finally { cleanup(dir); }\n290\t});\n291\t"}]},"parent_tool_use_id":null,"session_id":"96e7dda7-b960-48d1-b1cb-90373ff412c9","uuid":"f23583fa-37b9-4756-b911-642cc1704f96","timestamp":"2026-04-21T23:32:24.578Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/david/projects/GSD-T/test/m43-in-session-usage.test.js","content":"'use strict';\n/**\n * M43 D1 — in-session usage capture (Branch B: transcript-sourced).\n *\n * Covers:\n *   - One-turn: fabricated transcript with 1 assistant usage line → 1 v2 row\n *   - Multi-turn: 3 assistant usage lines → 3 v2 rows, distinct turn_id\n *   - Dedup: repeated hook fire over the same transcript emits zero new rows\n *   - Appended turns: a new turn after a cursor → exactly the delta emitted\n *   - Missing usage: assistant line without `usage` is ignored (no row)\n *   - Non-assistant lines: user lines are skipped\n *   - Missing transcript: processHookPayload returns reason=missing-*\n *   - captureInSessionUsage: direct call with null usage writes an `—` row\n */\n\nconst test = require('node:test');\nconst assert = require('node:assert/strict');\nconst fs = require('node:fs');\nconst os = require('node:os');\nconst path = require('node:path');\n\nconst inSession = require('../bin/gsd-t-in-session-usage.cjs');\n\nfunction makeTmpProject() {\n  const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'gsd-t-m43-d1-'));\n  fs.mkdirSync(path.join(dir, '.gsd-t'), { recursive: true });\n  return dir;\n}\n\nfunction cleanup(dir) {\n  try { fs.rmSync(dir, { recursive: true, force: true }); } catch (_) {}\n}\n\nfunction writeTranscript(dir, name, lines) {\n  const p = path.join(dir, name);\n  fs.writeFileSync(p, lines.map(l => JSON.stringify(l)).join('\\n') + '\\n');\n  return p;\n}\n\nfunction readJsonlLines(p) {\n  if (!fs.existsSync(p)) return [];\n  return fs.readFileSync(p, 'utf8').split('\\n').filter(Boolean).map(JSON.parse);\n}\n\nfunction assistantLine(id, usage, tsIso) {\n  return {\n    type: 'assistant',\n    uuid: `uuid-${id}`,\n    timestamp: tsIso || '2026-04-21T23:00:00.000Z',\n    message: {\n      id: `msg_${id}`,\n      model: 'claude-opus-4-7',\n      role: 'assistant',\n      usage,\n    },\n  };\n}\n\nconst USAGE_A = { input_tokens: 10, output_tokens: 5, cache_read_input_tokens: 100, cache_creation_input_tokens: 0, total_cost_usd: 0.01 };\nconst USAGE_B = { input_tokens: 12, output_tokens: 7, cache_read_input_tokens: 110, cache_creation_input_tokens: 3, total_cost_usd: 0.02 };\nconst USAGE_C = { input_tokens: 8,  output_tokens: 4, cache_read_input_tokens: 120, cache_creation_input_tokens: 1, total_cost_usd: 0.015 };\n\n// ── One-turn ──────────────────────────────────────────────────────────────\n\ntest('D1: one assistant turn → one in-session v2 row', () => {\n  const dir = makeTmpProject();\n  try {\n    const tp = writeTranscript(dir, 'transcript.jsonl', [\n      assistantLine('a', USAGE_A),\n    ]);\n    const r = inSession.processHookPayload({\n      projectDir: dir,\n      payload: {\n        session_id: 'session-1',\n        transcript_path: tp,\n        cwd: dir,\n        hook_event_name: 'Stop',\n      },\n    });\n    assert.equal(r.emitted, 1);\n    assert.equal(r.sessionId, 'session-1');\n\n    const rows = readJsonlLines(path.join(dir, '.gsd-t', 'metrics', 'token-usage.jsonl'));\n    assert.equal(rows.length, 1);\n    assert.equal(rows[0].schemaVersion, 2);\n    assert.equal(rows[0].sessionType, 'in-session');\n    assert.equal(rows[0].session_id, 'session-1');\n    assert.equal(rows[0].turn_id, 'msg_a');\n    assert.equal(rows[0].inputTokens, 10);\n    assert.equal(rows[0].outputTokens, 5);\n    assert.equal(rows[0].cacheReadInputTokens, 100);\n    assert.equal(rows[0].costUSD, 0.01);\n    assert.equal(rows[0].model, 'claude-opus-4-7');\n  } finally { cleanup(dir); }\n});\n\n// ── Multi-turn ────────────────────────────────────────────────────────────\n\ntest('D1: three assistant turns → three rows with distinct turn_id', () => {\n  const dir = makeTmpProject();\n  try {\n    const tp = writeTranscript(dir, 'transcript.jsonl', [\n      assistantLine('a', USAGE_A, '2026-04-21T23:00:00.000Z'),\n      assistantLine('b', USAGE_B, '2026-04-21T23:01:00.000Z'),\n      assistantLine('c', USAGE_C, '2026-04-21T23:02:00.000Z'),\n    ]);\n    const r = inSession.processHookPayload({\n      projectDir: dir,\n      payload: { session_id: 'session-multi', transcript_path: tp, cwd: dir, hook_event_name: 'Stop' },\n    });\n    assert.equal(r.emitted, 3);\n\n    const rows = readJsonlLines(path.join(dir, '.gsd-t', 'metrics', 'token-usage.jsonl'));\n    assert.equal(rows.length, 3);\n    const turnIds = rows.map(r => r.turn_id);\n    assert.deepEqual(turnIds, ['msg_a', 'msg_b', 'msg_c']);\n    assert.ok(rows.every(r => r.session_id === 'session-multi'));\n    assert.ok(rows.every(r => r.sessionType === 'in-session'));\n  } finally { cleanup(dir); }\n});\n\n// ── Dedup: repeated hook fire ─────────────────────────────────────────────\n\ntest('D1: repeated hook fire over same transcript emits zero new rows', () => {\n  const dir = makeTmpProject();\n  try {\n    const tp = writeTranscript(dir, 'transcript.jsonl', [\n      assistantLine('a', USAGE_A),\n      assistantLine('b', USAGE_B),\n    ]);\n    const payload = { session_id: 'session-dedup', transcript_path: tp, cwd: dir, hook_event_name: 'Stop' };\n\n    const r1 = inSession.processHookPayload({ projectDir: dir, payload });\n    assert.equal(r1.emitted, 2);\n\n    const r2 = inSession.processHookPayload({ projectDir: dir, payload });\n    assert.equal(r2.emitted, 0);\n    assert.equal(r2.skipped, 2);\n\n    const rows = readJsonlLines(path.join(dir, '.gsd-t', 'metrics', 'token-usage.jsonl'));\n    assert.equal(rows.length, 2);\n  } finally { cleanup(dir); }\n});\n\n// ── Appended-turn delta ───────────────────────────────────────────────────\n\ntest('D1: a turn appended after first fire emits exactly one new row', () => {\n  const dir = makeTmpProject();\n  try {\n    const tp = path.join(dir, 'transcript.jsonl');\n    fs.writeFileSync(tp, JSON.stringify(assistantLine('a', USAGE_A)) + '\\n');\n    const payload = { session_id: 'session-delta', transcript_path: tp, cwd: dir, hook_event_name: 'Stop' };\n\n    const r1 = inSession.processHookPayload({ projectDir: dir, payload });\n    assert.equal(r1.emitted, 1);\n\n    fs.appendFileSync(tp, JSON.stringify(assistantLine('b', USAGE_B)) + '\\n');\n    const r2 = inSession.processHookPayload({ projectDir: dir, payload });\n    assert.equal(r2.emitted, 1);\n    assert.equal(r2.skipped, 1);\n\n    const rows = readJsonlLines(path.join(dir, '.gsd-t', 'metrics', 'token-usage.jsonl'));\n    assert.equal(rows.length, 2);\n    assert.deepEqual(rows.map(r => r.turn_id), ['msg_a', 'msg_b']);\n  } finally { cleanup(dir); }\n});\n\n// ── Missing usage / non-assistant lines ───────────────────────────────────\n\ntest('D1: assistant line without usage is ignored; user lines are skipped', () => {\n  const dir = makeTmpProject();\n  try {\n    const tp = writeTranscript(dir, 'transcript.jsonl', [\n      { type: 'user', uuid: 'u-1', timestamp: '2026-04-21T23:00:00Z', message: { role: 'user', content: 'hi' } },\n      { type: 'assistant', uuid: 'a-no-usage', timestamp: '2026-04-21T23:00:01Z', message: { id: 'msg_noup', model: 'claude-opus-4-7', role: 'assistant' } },\n      assistantLine('good', USAGE_A, '2026-04-21T23:00:02Z'),\n    ]);\n    const r = inSession.processHookPayload({\n      projectDir: dir,\n      payload: { session_id: 'session-filter', transcript_path: tp, cwd: dir, hook_event_name: 'Stop' },\n    });\n    assert.equal(r.emitted, 1);\n    const rows = readJsonlLines(path.join(dir, '.gsd-t', 'metrics', 'token-usage.jsonl'));\n    assert.equal(rows.length, 1);\n    assert.equal(rows[0].turn_id, 'msg_good');\n  } finally { cleanup(dir); }\n});\n\n// ── Missing transcript / missing session ──────────────────────────────────\n\ntest('D1: missing transcript_path returns reason=missing-session-or-transcript', () => {\n  const dir = makeTmpProject();\n  try {\n    const r = inSession.processHookPayload({\n      projectDir: dir,\n      payload: { session_id: 'session-x', cwd: dir, hook_event_name: 'Stop' },\n    });\n    assert.equal(r.emitted, 0);\n    assert.equal(r.reason, 'missing-session-or-transcript');\n  } finally { cleanup(dir); }\n});\n\ntest('D1: non-existent transcript returns reason=no-turns (graceful)', () => {\n  const dir = makeTmpProject();\n  try {\n    const r = inSession.processHookPayload({\n      projectDir: dir,\n      payload: {\n        session_id: 'session-x',\n        transcript_path: path.join(dir, 'does-not-exist.jsonl'),\n        cwd: dir,\n        hook_event_name: 'Stop',\n      },\n    });\n    assert.equal(r.emitted, 0);\n    assert.equal(r.reason, 'no-turns');\n  } finally { cleanup(dir); }\n});\n\n// ── Direct captureInSessionUsage — null usage emits `—` row ───────────────\n\ntest('D1: captureInSessionUsage with null usage writes a row with hasUsage=false', () => {\n  const dir = makeTmpProject();\n  try {\n    inSession.captureInSessionUsage({\n      projectDir: dir,\n      sessionId: 'session-direct',\n      turnId: 'msg_direct',\n      usage: null,\n    });\n    const rows = readJsonlLines(path.join(dir, '.gsd-t', 'metrics', 'token-usage.jsonl'));\n    assert.equal(rows.length, 1);\n    assert.equal(rows[0].hasUsage, false);\n    assert.equal(rows[0].sessionType, 'in-session');\n    assert.equal(rows[0].session_id, 'session-direct');\n    assert.equal(rows[0].turn_id, 'msg_direct');\n    // In-session path writes JSONL only (skipMarkdownLog=true). The markdown\n    // log is regenerated on demand via `gsd-t tokens --regenerate-log`.\n    assert.equal(\n      fs.existsSync(path.join(dir, '.gsd-t', 'token-log.md')),\n      false,\n      'token-log.md should NOT be written by per-turn in-session capture',\n    );\n  } finally { cleanup(dir); }\n});\n\ntest('D1: multi-turn emission does NOT append to token-log.md (JSONL-only)', () => {\n  const dir = makeTmpProject();\n  try {\n    const tp = writeTranscript(dir, 'transcript.jsonl', [\n      assistantLine('a', USAGE_A),\n      assistantLine('b', USAGE_B),\n      assistantLine('c', USAGE_C),\n    ]);\n    inSession.processHookPayload({\n      projectDir: dir,\n      payload: { session_id: 'session-md', transcript_path: tp, cwd: dir, hook_event_name: 'Stop' },\n    });\n    assert.equal(\n      fs.existsSync(path.join(dir, '.gsd-t', 'token-log.md')),\n      false,\n      'token-log.md should stay untouched by in-session captures',\n    );\n    const rows = readJsonlLines(path.join(dir, '.gsd-t', 'metrics', 'token-usage.jsonl'));\n    assert.equal(rows.length, 3);\n  } finally { cleanup(dir); }\n});\n\n// ── Real probe payload shape (golden-style) ───────────────────────────────\n\ntest('D1: real-probe-shaped payload (session_id + transcript_path + cwd) processes without error', () => {\n  const dir = makeTmpProject();\n  try {\n    const tp = writeTranscript(dir, 'transcript.jsonl', [\n      assistantLine('real', USAGE_A),\n    ]);\n    const payload = {\n      session_id: 'a5ee3b8e-1a77-4950-ab8d-f108af026c1d',\n      transcript_path: tp,\n      cwd: dir,\n      permission_mode: 'bypassPermissions',\n      hook_event_name: 'Stop',\n      stop_hook_active: false,\n      last_assistant_message: 'truncated...',\n    };\n    const r = inSession.processHookPayload({ projectDir: dir, payload });\n    assert.equal(r.emitted, 1);\n    assert.equal(r.sessionId, 'a5ee3b8e-1a77-4950-ab8d-f108af026c1d');\n  } finally { cleanup(dir); }\n});\n","numLines":291,"startLine":1,"totalLines":291}}}
