vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

classes: {
  cmd: {
    shape: rectangle
    style: {
      fill: "#dbeafe"
      stroke: "#1e3a8a"
      stroke-width: 2
      font-color: "#1e3a8a"
      border-radius: 6
    }
  }
  router: {
    shape: hexagon
    style: {
      fill: "#ffe4e6"
      stroke: "#9f1239"
      stroke-width: 2
      font-color: "#9f1239"
      bold: true
    }
  }
  decision: {
    shape: diamond
    style: {
      fill: "#fef3c7"
      stroke: "#92400e"
      stroke-width: 2
      font-color: "#92400e"
    }
  }
  subagent: {
    shape: rectangle
    style: {
      fill: "#f3e8ff"
      stroke: "#6b21a8"
      stroke-width: 2
      stroke-dash: 3
      font-color: "#6b21a8"
      border-radius: 6
    }
  }
  endpoint: {
    shape: oval
    style: {
      fill: "#f3f4f6"
      stroke: "#374151"
      stroke-width: 2
      font-color: "#374151"
    }
  }
  artifact: {
    shape: cylinder
    style: {
      fill: "#fefce8"
      stroke: "#854d0e"
      stroke-width: 1
      font-color: "#713f12"
    }
  }
  gate: {
    shape: rectangle
    style: {
      fill: "#fee2e2"
      stroke: "#991b1b"
      stroke-width: 2
      font-color: "#991b1b"
      border-radius: 6
    }
  }
  group: {
    style: {
      fill: "#fafafa"
      stroke: "#9ca3af"
      stroke-width: 1
      stroke-dash: 2
      font-color: "#374151"
    }
  }
}
